{
    "name": "avi7223/bagisto-courier",
    "description": "Professional, extensible multi-courier integration package for Bagisto (SteadFast, Pathao and more via a driver pattern).",
    "type": "library",
    "license": "MIT",
    "keywords": ["bagisto", "laravel", "courier", "steadfast", "pathao", "shipping", "logistics"],
    "homepage": "https://github.com/Avi7223/bagisto-courier",
    "authors": [
        {
            "name": "Avi"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^9.0|^10.0|^11.0|^12.0",
        "illuminate/database": "^9.0|^10.0|^11.0|^12.0",
        "illuminate/queue": "^9.0|^10.0|^11.0|^12.0",
        "guzzlehttp/guzzle": "^7.5"
    },
    "require-dev": {
        "orchestra/testbench": "^7.0|^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^9.0|^10.0"
    },
    "autoload": {
        "psr-4": {
            "Rajibbinalam\\BagistoCourier\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Rajibbinalam\\BagistoCourier\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Rajibbinalam\\BagistoCourier\\Providers\\CourierServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
